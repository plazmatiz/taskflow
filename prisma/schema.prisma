datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Додайте цей рядок
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// Моделі для NextAuth.js (Автентифікація)
// ==========================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  githubUsername String?   @unique // Для автоматичного пошуку автора комітів

  accounts       Account[]
  sessions       Session[]
  projects       ProjectMember[]
  assignedTasks  Task[]
  commits        Commit[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Доменні моделі (Логіка додатку)
// ==========================================

model Project {
  id           String          @id @default(cuid())
  name         String
  repoFullName String?         
  isArchived   Boolean         @default(false) 
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  tasks        Task[]
  members      ProjectMember[]
}

model ProjectMember {
  projectId String
  userId    String
  role      String         // Рекомендовано: "ADMIN" | "MEMBER"
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  status      String        @default("TODO")
  branchName  String?       
  prUrl       String?      
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId  String?
  assignee    User?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  
  sessions    TaskSession[]
  commits     Commit[]
}

model TaskSession {
  id        String    @id @default(cuid())
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now())
  endedAt   DateTime? // null означає, що робота над задачею триває прямо зараз
}

model Commit {
  id        String   @id @default(cuid())
  sha       String   @unique
  message   String
  additions Int      @default(0)
  deletions Int      @default(0)
  createdAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}